# Copiez ce fichier en ".streamlit/secrets.toml" (en local) ou collez son
# contenu dans Settings → Secrets de votre application sur share.streamlit.io.
# Ne commitez jamais votre vrai fichier secrets.toml dans Git.

# Code d'accès unique du Super Admin (laissez tel quel ou changez-le).
SUPER_ADMIN_CODE = "labscsm32015@10001b"

# Configuration SMTP optionnelle pour l'envoi réel des messages du formulaire
# de support vers support@scsmaubmar.org. Si cette section est absente,
# les messages restent enregistrés et visibles dans le back-office, mais ne
# sont pas envoyés par e-mail automatiquement.
[smtp]
host = "smtp.gmail.com"
port = 587
use_tls = true
user = "votre-compte-envoi@exemple.com"
password = "mot-de-passe-application"
sender = "no-reply@cafedigit.cm"
